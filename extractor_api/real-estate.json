                        "type": "number"
                      },
                      "condition": {
                        "type": "string"
                      },
                      "furnished": {
                        "type": "boolean"
                      },
                      "year_built": {
                        "type": "integer"
                      },
                      "heating": {
                        "type": "boolean"
                      },
                      "gas": {
                        "type": "boolean"
                      },
                      "water": {
                        "type": "boolean"
                      },
                      "electricity": {
                        "type": "boolean"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      {
        "if": {
          "properties": {
