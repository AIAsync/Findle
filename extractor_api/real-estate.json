{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Real Estate Schema",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "Category name",
        "enum": [
          "Apartments",
          "Houses",
          "Townhouses",
          "Rooms",
          "Cottages",
          "Offices",
          "Retail space",
          "Restaurants and cafes",
          "Hotels",
          "Factories",
          "Warehouses",
          "Logistics centers",
          "Agricultural land",
          "Residential land",
          "Commercial land",
          "Medical centers",
          "Educational institutions",
          "Sports complexes",
          "Garages",
          "Parking spaces",
          "Parking lots",
          "Salons",
          "Shops and boutiques",
          "Plots",
          "Hostels"
        ]
      },
      "items": {
        "type": "array",
        "description": "List of items belonging to this category",
        "items": {
          "type": "object",
          "properties": {
            "property_type": {
              "type": "string",
              "description": "Property Type"
            },
            "transaction_type": {
              "type": "string",
              "description": "Transaction Type"
            },
            "payment_terms": {
              "type": "string",
              "description": "Payment Terms"
            },
            "total_area": {
              "type": "number",
              "description": "Total Area"
            },
            "region": {
              "type": "string",
              "description": "Region"
            },
            "district": {
              "type": "string",
              "description": "District"
            },
            "address": {
              "type": "string",
              "description": "Address"
            },
            "landmark": {
              "type": "string",
              "description": "Landmark"
            },
            "location": {
              "type": "object",
              "description": "Location: Latitude/Longitude",
              "properties": {
                "latitude": {
                  "type": "number"
                },
                "longitude": {
                  "type": "number"
                }
              },
              "required": [
                "latitude",
                "longitude"
              ]
            },
            "document_status": {
              "type": "string",
              "description": "Document Status"
            },
            "contact": {
              "type": "string",
              "description": "Contact"
            },
            "specs": {
              "type": "object",
              "description": "Specific features depending on the category"
            }
          },
          "required": [
            "property_type",
            "transaction_type",
            "payment_terms",
            "total_area",
            "region",
            "district",
            "address",
            "document_status",
            "contact"
          ]
        }
      }
    },
    "required": [
      "name",
      "items"
    ],
    "allOf": [
      {
        "if": {
          "properties": {
            "name": {
              "const": "Apartments"
            }
          }
        },
        "then": {
          "properties": {
            "items": {
              "items": {
                "properties": {
                  "specs": {
                    "type": "object",
                    "properties": {
                      "rooms": {
                        "type": "integer"
                      },
                      "floor": {
                        "type": "integer"
                      },
                      "total_floors": {
                        "type": "integer"
                      },
                      "building_type": {
                        "type": "string"
                      },
                      "condition": {
                        "type": "string"
                      },
                      "furnished": {
                        "type": "boolean"
                      },
                      "ceiling_height": {
                        "type": "number"
                      },
                      "year_built": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      {
        "if": {
          "properties": {
            "name": {
